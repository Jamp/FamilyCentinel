# =============================================================================
# FamilyCentinel — Variables de entorno (ejemplo)
# Copia a .env y rellena con tus credenciales reales.
# .env NUNCA debe commitearse (ya está en .gitignore).
# =============================================================================

# Broker MQTT (Home Assistant / Mosquitto)
MQTT_HOST=192.168.1.10
MQTT_PORT=1883
MQTT_USERNAME=familycentinel
MQTT_PASSWORD=cambiame_por_una_password_fuerte

# Zona horaria
TZ=Europe/Madrid
